<Page x:Class="CloneShop.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProfilePage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="190"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Профиль пользователя"
                       Style="{StaticResource PageHeaderTextStyle}"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Style="{StaticResource MainButtonStyle}"
                    Width="90"
                    Click="btnBack_Click"/>
        </Grid>

        <!-- Данные пользователя -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10,5,10,5"
                Padding="15">
            <StackPanel>
                <TextBlock x:Name="tbFullName"
                           Text="Имя:"
                           FontSize="22"
                           FontWeight="Bold"/>

                <TextBlock x:Name="tbLogin"
                           Text="Логин:"
                           Margin="0,10,0,0"
                           Style="{StaticResource MutedTextStyle}"/>

                <TextBlock x:Name="tbEmail"
                           Text="Email:"
                           Margin="0,10,0,0"
                           Style="{StaticResource MutedTextStyle}"/>

                <TextBlock x:Name="tbPhone"
                           Text="Телефон:"
                           Margin="0,10,0,0"
                           Style="{StaticResource MutedTextStyle}"/>

                <TextBlock x:Name="tbCreatedAt"
                           Text="Дата регистрации:"
                           Margin="0,10,0,0"
                           Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>
        </Border>

        <!-- Заказы и чеки -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="История заказов"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <ListView x:Name="lvOrders"
                      Grid.Row="1"
                      Margin="0,10,0,10"
                      Background="Transparent"
                      BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding OrderID, StringFormat=Заказ #{0}}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding OrderDate, StringFormat=Дата: {0}}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding TotalAmount, StringFormat=Сумма: {0} ₽}"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>

                                <TextBlock Grid.Column="3"
                                           Text="{Binding OrderStatuses.StatusName}"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock Grid.Row="2"
                       Text="Чеки"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <ListView x:Name="lvReceipts"
                      Grid.Row="3"
                      Margin="0,10,0,0"
                      Background="Transparent"
                      BorderThickness="0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding ReceiptID, StringFormat=Чек #{0}}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding CreatedAt, StringFormat=Дата: {0}}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding PdfPath}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"/>

                                <Button Grid.Column="3"
                                        Content="Открыть"
                                        Width="90"
                                        Height="30"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Tag="{Binding}"
                                        Style="{StaticResource MainButtonStyle}"
                                        Click="btnOpenReceipt_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>