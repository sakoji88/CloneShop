<Page x:Class="CloneShop.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CloneShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage">

    <Grid Background="#FF202020">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Background="#2D2D30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Каталог товаров"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Button Grid.Column="1"
                    x:Name="btnExit"
                    Content="Выйти"
                    Width="100"
                    Height="35"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnExit_Click"/>
        </Grid>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Блок информации о пользователе -->
            <StackPanel Grid.Row="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock x:Name="tbWelcome"
                           Text="Добро пожаловать"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock x:Name="tbRole"
                           Text="Роль:"
                           FontSize="16"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>

                <Button x:Name="btnAdmin"
                        Content="Админ-панель"
                        Width="150"
                        Height="35"
                        Margin="0,15,0,0"
                        Visibility="Collapsed"
                        Click="btnAdmin_Click"/>
                <TextBlock x:Name="tbSearch"
                           Text="Поиск"
                           Margin="0,20,0,0"
                           HorizontalAlignment="Center"/>
                <TextBox x:Name="txtSearch"
                         Width="200"
                         Height="30"
                         Margin="0,0,0,0"/>

            </StackPanel>

            <!-- Список товаров -->
            <ListView x:Name="lvProducts"
                      Grid.Row="1"
                      Margin="10">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="5"
                                Padding="10"
                                Background="White">
                            <StackPanel>
                                <TextBlock Text="{Binding ProductName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽}"
                                           Margin="0,5,0,0"/>

                                <TextBlock Text="{Binding QuantityInStock, StringFormat=Остаток: {0}}"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
