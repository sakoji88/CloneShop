<Page x:Class="CloneShop.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CloneShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CatalogPage">

    <Grid Background="#FF202020">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Background="#2D2D30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Каталог товаров"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>
            <Button x:Name="btnAdmin"
                    Grid.Column="1"
                    Content="Админ-панель"
                    Width="150"
                    Height="35"
                    Margin="0,0,90,0"
                    
                    Click="btnAdmin_Click"/>

            <Button Grid.Column="1"
                    x:Name="btnExit"
                    Content="Выйти"
                    Width="100"
                    Height="35"
                    Margin="170,0,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnExit_Click"/>
        </Grid>

        <!-- Основной контент -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Блок информации о пользователе -->
            <Grid Grid.Row="0" Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть -->
                <StackPanel Grid.Column="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock x:Name="tbWelcome"
                   Text="Добро пожаловать"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center" Foreground="White"/>

                    <TextBlock x:Name="tbRole"
                   Text="Роль:"
                   FontSize="16"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center" Foreground="White"/>
                </StackPanel>

                <!-- Правая часть -->
                <StackPanel Grid.Column="1"
                Margin="-200,30,0,0"
                            Width="430"
                
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="13*"/>
                            <RowDefinition Height="33*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Сортировка -->
                        <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Top" Grid.RowSpan="2">
                            <TextBlock Text="Сортировка"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbSort"
                  Width="130"
                  Height="25" SelectionChanged="cmbSort_SelectionChanged"/>
                        </StackPanel>

                        <!-- Категория -->
                        <StackPanel Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Top" Grid.RowSpan="2">
                            <TextBlock Text="Категория"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>
                            <ComboBox x:Name="cmbCategory"
                  Width="130"
                  Height="25"
                  SelectionChanged="cmbCategory_SelectionChanged"/>
                        </StackPanel>

                        <!-- Поиск -->
                        <StackPanel Grid.Column="2"
                HorizontalAlignment="Center"
                VerticalAlignment="Top" Grid.RowSpan="2">
                            <TextBlock Text="Поиск"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,5"/>
                            <TextBox x:Name="txtSearch"
                 Width="130"
                 Height="25"
                 TextChanged="txtSearch_TextChanged"/>
                        </StackPanel>
                    </Grid>


                </StackPanel>
            </Grid>

            <!-- Список товаров -->
            <ListView x:Name="lvProducts"
                      Grid.Row="1"
                      Margin="10">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black"
                                BorderThickness="1"
                                CornerRadius="8"
                                Margin="5"
                                Padding="10"
                                Background="White">
                            <StackPanel>
                                <TextBlock Text="{Binding ProductName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽}"
                                           Margin="0,5,0,0"/>

                                <TextBlock Text="{Binding QuantityInStock, StringFormat=Остаток: {0}}"
                                           Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
