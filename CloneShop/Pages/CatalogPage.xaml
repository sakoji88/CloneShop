<Page x:Class="CloneShop.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="CatalogPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="170"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="500"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Каталог товаров"
                       Style="{StaticResource PageHeaderTextStyle}"/>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <Button x:Name="btnProfile"
                        Content="Профиль"
                        Style="{StaticResource MainButtonStyle}"
                        Click="btnProfile_Click"/>

                <Button x:Name="btnCart"
                        Content="Корзина"
                        Style="{StaticResource MainButtonStyle}" Click="btnCart_Click_1">
                    
                </Button>
                        

                <Button x:Name="btnQr"
                        Content="Поддержка"
                        Style="{StaticResource MainButtonStyle}"
                        Click="btnQr_Click"/>

                <Button x:Name="btnExit"
                        Content="Выйти"
                        Style="{StaticResource MainButtonStyle}"
                        Click="btnExit_Click"/>
            </StackPanel>
        </Grid>

        <!-- Информация о пользователе + фильтры -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="420"/>
                </Grid.ColumnDefinitions>

                <!-- Левая часть -->
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="tbWelcome"
                               Text="Добро пожаловать"
                               FontSize="24"
                               FontWeight="Bold"/>

                    <Button x:Name="btnAdmin"
                            Content="Админ-панель"
                            Style="{StaticResource MainButtonStyle}"
                            Width="160"
                            Margin="0,15,0,0"
                            Visibility="Collapsed"
                            Click="btnAdmin_Click"/>
                </StackPanel>

                <!-- Правая часть -->
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Сортировка -->
                    <StackPanel Grid.Column="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Сортировка"
                                   Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbSort"
                                  Width="130"
                                  Style="{StaticResource MainComboBoxStyle}"
                                  SelectionChanged="cmbSort_SelectionChanged"/>
                    </StackPanel>

                    <!-- Категория -->
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Категория"
                                   Margin="0,0,0,5"/>
                        <ComboBox x:Name="cmbCategory"
                                  Width="130"
                                  Style="{StaticResource MainComboBoxStyle}"
                                  SelectionChanged="cmbCategory_SelectionChanged"/>
                    </StackPanel>

                    <!-- Поиск -->
                    <StackPanel Grid.Column="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="Поиск"
                                   Margin="0,0,0,5"/>
                        <TextBox x:Name="txtSearch"
                                 Width="130"
                                 Style="{StaticResource MainTextBoxStyle}"
                                 TextChanged="txtSearch_TextChanged"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Список товаров -->
        <ListView x:Name="lvProducts"
                  Grid.Row="2"
                  Margin="10"
                  Background="Transparent"
                  BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="1580"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <!-- Главная картинка -->
                            <Border Grid.Column="0"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,10,0">
                                <Image Source="{Binding ImagePath}"
                                       Width="120"
                                       Height="120"
                                       Stretch="UniformToFill"/>
                            </Border>

                            <!-- Информация -->
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ProductName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>

                                <TextBlock Text="{Binding Price, StringFormat=Цена: {0} ₽}"
                                           Margin="0,8,0,0"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>

                                <TextBlock Text="{Binding QuantityInStock, StringFormat=Остаток: {0}}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,5,0,0"/>

                                <TextBlock Text="{Binding Description}"
                                           Style="{StaticResource MutedTextStyle}"
                                           Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           MaxHeight="50"/>
                            </StackPanel>

                            <!-- Кнопки -->
                            <StackPanel Grid.Column="2"
                                        VerticalAlignment="Center">
                                <Button Content="В корзину"
                                        Tag="{Binding SourceProduct}"
                                        Style="{StaticResource MainButtonStyle}"
                                        Height="30"
                                        Margin="0,0,0,10"
                                        Click="btnAddToCart_Click"/>

                                <Button Content="Подробнее"
                                        Tag="{Binding SourceProduct}"
                                        Style="{StaticResource MainButtonStyle}"
                                        Height="30"
                                        Click="btnDetails_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>