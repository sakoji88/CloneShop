<Page x:Class="CloneShop.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CloneShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CartPage">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Background="#FF202020">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Корзина"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Width="90"
                    Height="35"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <!-- Список товаров -->
        <ListView x:Name="lvCartItems"
                  Grid.Row="1"
                  Margin="10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Black"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="5"
                            Padding="10"
                            Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding ProductName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding PriceAtMoment, StringFormat=Цена: {0} ₽}"
                                           Margin="0,5,0,0"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Quantity, StringFormat=Количество: {0}}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding TotalPrice, StringFormat=Сумма: {0} ₽}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                            <Button Grid.Column="3"
                                    Content="Удалить"
                                    Width="90"
                                    Height="30"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Tag="{Binding}"
                                    Click="btnDelete_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель -->
        <Grid Grid.Row="2" Background="#EAEAEA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="tbTotal"
                       Grid.Column="0"
                       Text="Итог: 0 ₽"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Button x:Name="btnOrder"
                    Grid.Column="1"
                    Content="Оформить заказ"
                    Width="150"
                    Height="35"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnOrder_Click"/>
        </Grid>
    </Grid>
</Page>
