<Page x:Class="CloneShop.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CloneShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CartPage">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Grid Grid.Row="0" Background="#FF202020">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Корзина"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Width="90"
                    Height="35"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <!-- Список товаров -->
        <ListView x:Name="lvCartItems"
          Grid.Row="1"
          Margin="10"
          Background="Transparent"
          BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#D0D0D0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Margin="5"
                    Padding="10"
                    Background="White">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <!-- Картинка -->
                            <Border Grid.Column="0"
                            BorderBrush="#CCCCCC"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,10,0">
                                <Image Source="{Binding ImagePath}"
                               Width="90"
                               Height="90"
                               Stretch="UniformToFill"/>
                            </Border>

                            <!-- Информация -->
                            <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">
                                <TextBlock Text="{Binding ProductName}"
                                   FontSize="18"
                                   FontWeight="Bold"/>

                                <TextBlock Text="{Binding PriceAtMoment, StringFormat=Цена: {0} ₽}"
                                   Margin="0,6,0,0"
                                   Foreground="#444"/>

                                <TextBlock Text="{Binding TotalPrice, StringFormat=Сумма: {0} ₽}"
                                   Margin="0,6,0,0"
                                   FontWeight="SemiBold"/>
                            </StackPanel>

                            <!-- Количество -->
                            <StackPanel Grid.Column="2"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <TextBlock Text="Количество"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>

                                <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                                    <Button Content="-"
                                    Width="30"
                                    Height="30"
                                    Tag="{Binding}"
                                    Click="btnMinus_Click"/>

                                    <TextBlock Text="{Binding Quantity}"
                                       Width="40"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="Bold"/>

                                    <Button Content="+"
                                    Width="30"
                                    Height="30"
                                    Tag="{Binding}"
                                    Click="btnPlus_Click"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Сумма -->
                            <StackPanel Grid.Column="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <TextBlock Text="Итог"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding TotalPrice, StringFormat={}{0} ₽}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Удалить -->
                            <Button Grid.Column="4"
                            Content="Удалить"
                            Width="80"
                            Height="30"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Tag="{Binding}"
                            Click="btnDelete_Click"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Нижняя панель -->
        <Grid Grid.Row="2" Background="#EAEAEA">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="170"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="tbTotal"
               Grid.Column="0"
               Text="Итог: 0 ₽"
               FontSize="20"
               FontWeight="Bold"
               VerticalAlignment="Center"
               Margin="20,0,0,0"/>

            <Button x:Name="btnClearCart"
            Grid.Column="1"
            Content="Очистить корзину"
            Width="150"
            Height="35"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="btnClearCart_Click"/>

            <Button x:Name="btnOrder"
            Grid.Column="2"
            Content="Оформить заказ"
            Width="150"
            Height="35"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Click="btnOrder_Click"/>
        </Grid>
    </Grid>
</Page>
