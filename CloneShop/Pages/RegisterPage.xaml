<Page x:Class="CloneShop.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="RegisterPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Border Style="{StaticResource CardBorderStyle}"
                Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25">
            <StackPanel>

                <TextBlock Text="Регистрация"
                           FontSize="28"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Создание нового аккаунта"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Имя"/>
                <TextBox x:Name="txtName"
                         Style="{StaticResource MainTextBoxStyle}"/>

                <TextBlock Text="Логин"/>
                <TextBox x:Name="txtLogin"
                         Style="{StaticResource MainTextBoxStyle}"/>

                <TextBlock Text="Пароль"/>
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource MainPasswordBoxStyle}"/>

                <TextBlock Text="Повтор пароля"/>
                <PasswordBox x:Name="txtPasswordRepeat"
                             Style="{StaticResource MainPasswordBoxStyle}"/>

                <TextBlock Text="Email"/>
                <TextBox x:Name="txtEmail"
                         Style="{StaticResource MainTextBoxStyle}"/>

                <TextBlock Text="Телефон"/>
                <TextBox x:Name="txtPhone"
                         Style="{StaticResource MainTextBoxStyle}"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <Button x:Name="btnRegister"
                            Content="Зарегистрироваться"
                            Style="{StaticResource MainButtonStyle}"
                            Click="btnRegister_Click"/>

                    <Button x:Name="btnBack"
                            Content="Назад"
                            Style="{StaticResource MainButtonStyle}"
                            Click="btnBack_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>