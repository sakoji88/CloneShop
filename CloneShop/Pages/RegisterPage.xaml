<Page x:Class="CloneShop.Pages.RegisterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:CloneShop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RegisterPage">

    <Grid Background="#FF202020">
        <StackPanel
            Width="350"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <TextBlock 
           Text="Регистрация"
           FontSize="26"
           FontWeight="Bold"
           Foreground="Snow"
           Margin="0,0,0,5"
           HorizontalAlignment="Center"/>
            <TextBlock TextWrapping="Wrap" Text="Фио:" Foreground="White" Width="194" FontFamily="Segoe UI Semibold" FontSize="16" Margin="5"/>
            <TextBox x:Name="txtName" TextWrapping="Wrap" Height="20" Width="194"/>
            <TextBlock TextWrapping="Wrap" Text="Логин:" Foreground="White" Width="194" FontFamily="Segoe UI Semibold" FontSize="16" Margin="5"/>
            <TextBox x:Name="txtLogin" TextWrapping="Wrap" Height="20" Width="194"/>
            <TextBlock TextWrapping="Wrap" Text="Пароль:" Foreground="White" Width="194" FontFamily="Segoe UI Semibold" FontSize="16" Margin="5"/>
            <PasswordBox x:Name="txtPassword" Height="20" Width="194"/>
            <TextBlock TextWrapping="Wrap" Text="Повторите пароль:" Foreground="White" Width="194" FontFamily="Segoe UI Semibold" FontSize="16" Margin="5"/>
            <PasswordBox x:Name="txtPasswordRepeat" Height="20" Width="194"/>
            <TextBlock TextWrapping="Wrap" Text="Электронная почта:" Foreground="White" Width="194" FontFamily="Segoe UI Semibold" FontSize="16" Margin="5"/>
            <TextBox x:Name="txtEmail" TextWrapping="Wrap" Height="20" Width="194"/>
            <TextBlock TextWrapping="Wrap" Text="Номер телефона:" Foreground="White" Width="194" FontFamily="Segoe UI Semibold" FontSize="16" Margin="5"/>
            <TextBox x:Name="txtPhone" TextWrapping="Wrap" Height="20" Width="194"/>
            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Center">
                <Button x:Name="btnBack"
        Content="Назад"
       Width="150"
       Height="35"
       Margin="150,10,0,0" Click="btnBack_Click" Background="White"/>
                <Button x:Name="btnRegister"
           Content="Зарегистрироваться"
           Width="150"
           Height="35"
           Margin="30,10,150,0" Click="btnRegister_Click" Background="White"
           />
                



            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
