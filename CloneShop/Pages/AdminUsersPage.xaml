<Page x:Class="CloneShop.Pages.AdminUsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminUsersPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Админ-панель пользователей"
                       Style="{StaticResource PageHeaderTextStyle}"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Width="90"
                    Style="{StaticResource MainButtonStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <!-- Панель действий -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="btnChangeRole"
                        Content="Сменить роль"
                        Width="160"
                        Style="{StaticResource MainButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="btnChangeRole_Click"/>

                <Button Grid.Column="1"
                        x:Name="btnToggleBlock"
                        Content="Блок / разблок"
                        Width="160"
                        Style="{StaticResource DangerButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="btnToggleBlock_Click"/>
            </Grid>
        </Border>

        <!-- Список пользователей -->
        <ListView x:Name="lvUsers"
                  Grid.Row="2"
                  Margin="10"
                  Background="Transparent"
                  BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding FullName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding Login, StringFormat=Логин: {0}}"
                                           Margin="0,5,0,0"
                                           Style="{StaticResource MutedTextStyle}"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding Roles.RoleName}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding Email}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"/>

                            <TextBlock Grid.Column="3"
                                       Text="{Binding IsBlocked, StringFormat=Заблокирован: {0}}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>