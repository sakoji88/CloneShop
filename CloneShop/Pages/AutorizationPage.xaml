<Page x:Class="CloneShop.Pages.AuthorizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AuthorizationPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Border Style="{StaticResource CardBorderStyle}"
                Width="380"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Padding="25">
            <StackPanel>

                <TextBlock Text="Магазин клонов"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Вход в аккаунт"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <TextBlock Text="Логин"
                           Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin"
                         Style="{StaticResource MainTextBoxStyle}"
                         MaxLength="50"/>

                <TextBlock Text="Пароль"
                           Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource MainPasswordBoxStyle}"
                             MaxLength="50"/>

                <Button x:Name="btnLogin"
                        Content="Войти"
                        Style="{StaticResource MainButtonStyle}"
                        Margin="0,10,0,10"
                        Click="btnLogin_Click"/>

                <Button x:Name="btnReg"
                        Content="Регистрация"
                        Style="{StaticResource MainButtonStyle}"
                        Click="btnReg_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>