<Page x:Class="CloneShop.Pages.ProductDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="ProductDetailsPage">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="#2D2D30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Карточка товара"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>

            <Button Grid.Column="1"
                    Content="Назад"
                    Width="90"
                    Height="35"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <!-- Контент -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая часть -->
            <StackPanel Grid.Column="0">
                <Border BorderBrush="Black"
                        BorderThickness="1"
                        Background="White"
                        Padding="10">
                    <Image x:Name="imgMain"
                           Width="250"
                           Height="250"
                           Stretch="Uniform"/>
                </Border>

                <TextBlock Text="Дополнительные изображения"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,15,0,10"/>

                <ListBox x:Name="lbImages"
                         Height="220"
                         SelectionChanged="lbImages_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray"
                                    BorderThickness="1"
                                    Margin="3"
                                    Padding="3"
                                    Background="White">
                                <Image Source="{Binding}"
                                       Width="90"
                                       Height="90"
                                       Stretch="UniformToFill"/>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>

            <!-- Правая часть -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock x:Name="tbName"
                           FontSize="24"
                           FontWeight="Bold"/>

                <TextBlock x:Name="tbPrice"
                           FontSize="18"
                           Margin="0,15,0,0"/>

                <TextBlock x:Name="tbCategory"
                           FontSize="16"
                           Margin="0,10,0,0"/>

                <TextBlock x:Name="tbBrand"
                           FontSize="16"
                           Margin="0,10,0,0"/>

                <TextBlock x:Name="tbStatus"
                           FontSize="16"
                           Margin="0,10,0,0"/>

                <TextBlock x:Name="tbQuantity"
                           FontSize="16"
                           Margin="0,10,0,0"/>

                <TextBlock Text="Описание:"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,20,0,5"/>

                <TextBlock x:Name="tbDescription"
                           TextWrapping="Wrap"
                           FontSize="16"
                           MaxHeight="300"/>

                <Button x:Name="btnAddToCart"
                        Content="В корзину"
                        Width="150"
                        Height="35"
                        Margin="0,25,0,0"
                        Click="btnAddToCart_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>