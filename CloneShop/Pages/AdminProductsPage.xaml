<Page x:Class="CloneShop.Pages.AdminProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="AdminProductsPage">

    <Grid Background="{StaticResource PageBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка -->
        <Grid Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Админ-панель товаров"
                       Style="{StaticResource PageHeaderTextStyle}"/>

            <Button Grid.Column="1"
                    x:Name="btnBack"
                    Content="Назад"
                    Width="90"
                    Style="{StaticResource MainButtonStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Click="btnBack_Click"/>
        </Grid>

        <!-- Панель действий -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorderStyle}"
                Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        x:Name="btnAdd"
                        Content="Добавить товар"
                        Width="140"
                        Style="{StaticResource MainButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="btnAdd_Click"/>

                <Button Grid.Column="1"
                        x:Name="btnEdit"
                        Content="Редактировать"
                        Width="140"
                        Style="{StaticResource MainButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="btnEdit_Click"/>

                <Button Grid.Column="2"
                        x:Name="btnDelete"
                        Content="Удалить"
                        Width="140"
                        Style="{StaticResource DangerButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="btnDelete_Click"/>

                <Button Grid.Column="3"
                        x:Name="btnUsers"
                        Content="Пользователи"
                        Width="140"
                        Style="{StaticResource MainButtonStyle}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="btnUsers_Click"/>
            </Grid>
        </Border>

        <!-- Список товаров -->
        <ListView x:Name="lvAdminProducts"
                  Grid.Row="2"
                  Margin="10"
                  Background="Transparent"
                  BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>

                            <!-- Картинка -->
                            <Border Grid.Column="0"
                                    BorderBrush="#CCCCCC"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,10,0">
                                <Image Width="80"
                                       Height="80"
                                       Stretch="UniformToFill"/>
                            </Border>

                            <!-- Название -->
                            <StackPanel Grid.Column="1"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding ProductName}"
                                           FontSize="18"
                                           FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}"
                                           Style="{StaticResource MutedTextStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,5,0,0"
                                           MaxHeight="40"/>
                            </StackPanel>

                            <!-- Категория -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding Categories.CategoryName}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>

                            <!-- Цена -->
                            <TextBlock Grid.Column="3"
                                       Text="{Binding Price, StringFormat={}{0} ₽}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       FontWeight="SemiBold"/>

                            <!-- Остаток -->
                            <TextBlock Grid.Column="4"
                                       Text="{Binding QuantityInStock, StringFormat=Остаток: {0}}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>